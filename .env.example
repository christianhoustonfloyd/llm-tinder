# Supabase Postgres (from Supabase dashboard → Connect → ORMs → Prisma).
# Pooled (transaction mode, :6543) for the app at runtime; direct (session mode, :5432) for migrations.
# Replace <project-ref>, <region>, and [YOUR-PASSWORD] with your project's real values.
DATABASE_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@<region>.pooler.supabase.com:5432/postgres"

# Auth.js secret (used to sign session JWTs). Regenerate with: openssl rand -base64 33
AUTH_SECRET="generate-with-openssl-rand-base64-33"

# Google OAuth (Google Cloud Console → Credentials → OAuth client ID, Web application).
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Base URL Auth.js uses for OAuth callbacks (match the port you run on).
AUTH_URL="http://localhost:3100"
